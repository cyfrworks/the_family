# CYFR Server
CYFR_SECRET_KEY_BASE=generate-with-cyfr-init
CYFR_PORT=4000
CYFR_HOST=localhost
CYFR_GITHUB_CLIENT_ID=Ov23lib66tiIwXkgUpwm

# Frontend (Expo exposes EXPO_PUBLIC_ prefixed vars to the browser)
