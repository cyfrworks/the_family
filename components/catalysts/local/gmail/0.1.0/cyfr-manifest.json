{
  "name": "gmail",
  "type": "catalyst",
  "version": "0.1.0",
  "publisher": "local",
  "description": "Gmail API catalyst — list/read/send messages, manage labels, and fetch profile via OAuth 2.0",
  "wasi": {
    "http": true,
    "secrets": true,
    "streaming": false
  },
  "setup": {
    "secrets": [
      {
        "name": "GMAIL_CLIENT_ID",
        "description": "Google OAuth 2.0 Client ID (from Google Cloud Console → Credentials)",
        "required": true
      },
      {
        "name": "GMAIL_CLIENT_SECRET",
        "description": "Google OAuth 2.0 Client Secret (from Google Cloud Console → Credentials)",
        "required": true
      },
      {
        "name": "GMAIL_REFRESH_TOKEN",
        "description": "OAuth 2.0 Refresh Token for the target Gmail account (obtained via OAuth consent flow with gmail scope)",
        "required": true
      }
    ],
    "policy": {
      "allowed_domains": [
        "gmail.googleapis.com",
        "oauth2.googleapis.com"
      ],
      "allowed_methods": ["GET", "POST"],
      "timeout": "30s"
    }
  },
  "schema": {
    "input": {
      "type": "object",
      "required": ["operation"],
      "properties": {
        "operation": {
          "enum": [
            "list_messages",
            "get_message",
            "send_message",
            "list_labels",
            "get_profile"
          ],
          "description": "Gmail operation to perform"
        },
        "params": {
          "type": "object",
          "description": "Operation-specific parameters"
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "status": { "type": "integer" },
        "data": { "type": "object" },
        "error": { "type": "string" }
      }
    }
  },
  "examples": [
    {
      "name": "List recent inbox messages",
      "input": {
        "operation": "list_messages",
        "params": { "query": "in:inbox", "max_results": 10 }
      },
      "output": {
        "status": 200,
        "data": {
          "messages": [
            { "id": "18c1d...", "thread_id": "18c1d...", "snippet": "Hello there...", "subject": "Hello", "from": "sender@example.com", "date": "Mon, 1 Jan 2024 10:00:00 +0000", "label_ids": ["INBOX", "UNREAD"] }
          ],
          "result_size_estimate": 1
        }
      }
    },
    {
      "name": "Get a specific message",
      "input": {
        "operation": "get_message",
        "params": { "message_id": "18c1d...", "format": "full" }
      },
      "output": {
        "status": 200,
        "data": {
          "id": "18c1d...",
          "thread_id": "18c1d...",
          "label_ids": ["INBOX"],
          "snippet": "Hello there...",
          "subject": "Hello",
          "from": "sender@example.com",
          "to": "me@example.com",
          "date": "Mon, 1 Jan 2024 10:00:00 +0000",
          "body": "Hello there, how are you?"
        }
      }
    },
    {
      "name": "Send a message",
      "input": {
        "operation": "send_message",
        "params": {
          "to": "recipient@example.com",
          "subject": "Hello from CYFR",
          "body": "This message was sent via the Gmail catalyst.",
          "cc": "cc@example.com"
        }
      },
      "output": {
        "status": 200,
        "data": { "id": "18c1e...", "thread_id": "18c1e...", "label_ids": ["SENT"] }
      }
    },
    {
      "name": "List all labels",
      "input": { "operation": "list_labels", "params": {} },
      "output": {
        "status": 200,
        "data": {
          "labels": [
            { "id": "INBOX", "name": "INBOX", "type": "system" },
            { "id": "SENT", "name": "SENT", "type": "system" }
          ]
        }
      }
    },
    {
      "name": "Get account profile",
      "input": { "operation": "get_profile", "params": {} },
      "output": {
        "status": 200,
        "data": {
          "email_address": "me@example.com",
          "messages_total": 1234,
          "threads_total": 456,
          "history_id": "9876"
        }
      }
    }
  ]
}
