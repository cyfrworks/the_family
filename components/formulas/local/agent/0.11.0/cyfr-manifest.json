{
  "name": "agent",
  "type": "formula",
  "version": "0.11.0",
  "publisher": "local",
  "description": "Generic multi-provider agentic loop with dynamic MCP tool discovery",
  "setup": {
    "policy": {
      "allowed_tools": [
        "tools.list",
        "execution.run",
        "execution.list",
        "execution.logs",
        "execution.status",
        "execution.cancel",
        "execution.run_stream",
        "component.search",
        "component.inspect",
        "component.list",
        "component.categories",
        "component.pull",
        "component.new",
        "build.compile",
        "build.toolchains",
        "guide.list",
        "guide.get",
        "guide.readme",
        "config.get",
        "config.get_all",
        "config.list",
        "secret.list",
        "secret.can_access",
        "policy.show",
        "policy.list",
        "system.status",
        "storage.read",
        "storage.write",
        "storage.list",
        "schedule.create",
        "schedule.list",
        "schedule.pause",
        "schedule.resume",
        "schedule.delete",
        "component.setup_plan",
        "external.call",
        "mcp_servers.list",
        "mcp_servers.get",
        "mcp_servers.test",
        "mcp_servers.refresh"
      ],
      "timeout": "10m",
      "max_concurrent_tasks": 30,
      "max_request_size": 5242880,
      "max_response_size": 5242880,
      "batch_timeout": "5m"
    }
  },
  "dependencies": {
    "static": [
      { "ref": "catalyst:local.files", "optional": false, "reason": "File operations" },
      { "ref": "catalyst:moonmoon69.claude", "optional": false, "reason": "Claude LLM provider" },
      { "ref": "catalyst:moonmoon69.openai", "optional": false, "reason": "OpenAI LLM provider" },
      { "ref": "catalyst:moonmoon69.gemini", "optional": false, "reason": "Gemini LLM provider" },
      { "ref": "catalyst:moonmoon69.grok", "optional": false, "reason": "Grok LLM provider" },
      { "ref": "catalyst:moonmoon69.openrouter", "optional": false, "reason": "OpenRouter LLM provider" }
    ]
  },
  "schema": {
    "input": {
      "type": "object",
      "required": ["catalyst_ref", "model", "task", "system"],
      "properties": {
        "catalyst_ref": {
          "type": "string",
          "description": "LLM catalyst reference, e.g. catalyst:moonmoon69.claude:1.0.0"
        },
        "model": {
          "type": "string",
          "description": "Model identifier (e.g. claude-sonnet-4-5-20250514)"
        },
        "task": {
          "type": "string",
          "description": "Task or follow-up message"
        },
        "system": {
          "type": "string",
          "description": "Full system prompt (caller-composed)"
        },
        "messages": {
          "type": "array",
          "description": "Conversation history for continuation"
        },
        "visible_tools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tool names to expose to the LLM. Omit for all tools."
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "content": { "type": "string" },
        "turns": { "type": "integer" },
        "messages": {
          "type": "array",
          "description": "Full conversation history including tool_use/tool_result pairs"
        },
        "component_ref": { "type": "string" },
        "usage": {
          "type": "object",
          "description": "Accumulated token usage across all turns",
          "properties": {
            "input_tokens": { "type": "integer" },
            "output_tokens": { "type": "integer" }
          }
        }
      }
    }
  },
  "examples": [
    {
      "name": "General task with Claude",
      "input": {
        "catalyst_ref": "catalyst:moonmoon69.claude:1.0.0",
        "model": "claude-sonnet-4-5-20250514",
        "task": "List all Rust files in components/ and describe what each does",
        "system": "You are an agent running inside CYFR, a governed computation platform."
      }
    }
  ]
}
