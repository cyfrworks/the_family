{
  "name": "caporegime",
  "type": "formula",
  "publisher": "local",
  "version": "0.1.0",
  "description": "Caporegime — two-mode workflow orchestrator: Brain (agentic, LLM-driven) for interpreting orders, Hands (mechanical) for executing saved jobs",
  "setup": {
    "policy": {
      "allowed_tools": ["execution.run", "execution.list", "schedule.create", "schedule.list", "schedule.pause", "schedule.delete"],
      "timeout": "10m",
      "max_concurrent_tasks": 10,
      "batch_timeout": "5m"
    }
  },
  "schema": {
    "input": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "description": "Mode: 'respond' (Brain — agentic loop, default) or 'execute_job' (Hands — mechanical step executor)",
          "enum": ["respond", "execute_job"],
          "default": "respond"
        },
        "catalyst_ref": {
          "type": "string",
          "description": "LLM catalyst reference (required for 'respond' mode)"
        },
        "model": {
          "type": "string",
          "description": "Model identifier (required for 'respond' mode)"
        },
        "system": {
          "type": "string",
          "description": "Base system prompt (enriched with crew info automatically)"
        },
        "conversation": {
          "type": "array",
          "description": "Chat messages for context (respond mode)"
        },
        "sit_down_id": {
          "type": "string",
          "description": "Sit-down ID for message insertion and operation tracking"
        },
        "member_id": {
          "type": "string",
          "description": "Caporegime member ID (respond mode)"
        },
        "access_token": {
          "type": "string",
          "description": "Supabase access token"
        },
        "member": {
          "type": "object",
          "description": "Member object with name"
        },
        "context": {
          "type": "object",
          "description": "Additional context including owner_id"
        },
        "reply_to_id": {
          "type": "string",
          "description": "Message ID being replied to (respond mode)"
        },
        "max_turns": {
          "type": "integer",
          "description": "Maximum agentic loop turns (default: 30, respond mode only)"
        },
        "job_id": {
          "type": "string",
          "description": "Job ID to execute (execute_job mode)"
        },
        "steps": {
          "type": "array",
          "description": "Inline step definitions (execute_job mode, alternative to job_id)"
        },
        "caporegime_id": {
          "type": "string",
          "description": "Caporegime member ID (execute_job mode)"
        },
        "owner_id": {
          "type": "string",
          "description": "Owner user ID (execute_job mode)"
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "content": {
          "type": "string",
          "description": "Final report text (respond mode)"
        },
        "message_id": {
          "type": "string",
          "description": "Inserted report message ID"
        },
        "operation_id": {
          "type": "string",
          "description": "Operation record ID for tracking"
        },
        "turns": {
          "type": "integer",
          "description": "Number of agentic loop turns used (respond mode)"
        },
        "usage": {
          "type": "object",
          "description": "Aggregate token usage (respond mode)"
        },
        "status": {
          "type": "string",
          "description": "Execution status (execute_job mode)"
        },
        "result": {
          "type": "string",
          "description": "Final step output (execute_job mode)"
        }
      }
    }
  },
  "dependencies": {
    "static": [
      { "ref": "catalyst:moonmoon69.supabase:0.3.1", "reason": "DB operations" },
      { "ref": "catalyst:moonmoon69.claude:1.0.0", "reason": "Claude provider" },
      { "ref": "catalyst:moonmoon69.openai:1.0.0", "reason": "OpenAI provider" },
      { "ref": "catalyst:moonmoon69.gemini:1.0.0", "reason": "Gemini provider" },
      { "ref": "catalyst:moonmoon69.grok:1.0.0", "reason": "Grok provider" },
      { "ref": "catalyst:moonmoon69.openrouter:1.0.0", "reason": "OpenRouter provider" },
      { "ref": "formula:local.consul:0.1.0", "reason": "Soldier delegation via consul" },
      { "ref": "formula:local.bookkeeper:0.1.0", "reason": "Bookkeeper data operations" }
    ]
  },
  "examples": [
    {
      "name": "Brain mode — agentic task",
      "description": "Execute a multi-turn agentic operation with tool use and crew delegation",
      "input": {
        "action": "respond",
        "catalyst_ref": "catalyst:moonmoon69.claude:1.0.0",
        "model": "claude-sonnet-4-6",
        "system": "You handle operations for the Family.",
        "conversation": [{ "role": "user", "content": "Research the latest market trends and compile a report." }],
        "member": { "name": "The Caporegime" },
        "member_id": "mem-capo-1",
        "sit_down_id": "sd-1",
        "access_token": "eyJ...",
        "context": { "owner_id": "user-1" },
        "max_turns": 10
      },
      "output": {
        "content": "Operation complete. Here's the report...",
        "message_id": "msg-1",
        "operation_id": "op-1",
        "turns": 5,
        "usage": { "input_tokens": 5000, "output_tokens": 2000 }
      }
    },
    {
      "name": "Hands mode — execute a saved job",
      "description": "Mechanically execute a saved workflow without an orchestration LLM",
      "input": {
        "action": "execute_job",
        "job_id": "job-uuid",
        "caporegime_id": "mem-capo-1",
        "owner_id": "user-1",
        "access_token": "eyJ..."
      },
      "output": {
        "operation_id": "op-2",
        "status": "completed",
        "result": "Job output..."
      }
    }
  ]
}
