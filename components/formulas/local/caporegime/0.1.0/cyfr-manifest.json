{
  "name": "caporegime",
  "type": "formula",
  "publisher": "local",
  "version": "0.1.0",
  "description": "Caporegime member — agentic orchestrator with tool use, crew delegation, and operation tracking",
  "setup": {
    "policy": {
      "allowed_tools": ["execution.run", "execution.list", "tools.list"],
      "timeout": "10m",
      "max_concurrent_tasks": 10,
      "batch_timeout": "5m"
    }
  },
  "schema": {
    "input": {
      "type": "object",
      "required": ["catalyst_ref", "model"],
      "properties": {
        "catalyst_ref": {
          "type": "string",
          "description": "LLM catalyst reference to use for the agentic loop"
        },
        "model": {
          "type": "string",
          "description": "Model identifier for the catalyst"
        },
        "system": {
          "type": "string",
          "description": "Base system prompt (enriched with crew info automatically)"
        },
        "conversation": {
          "type": "array",
          "description": "Chat messages for context"
        },
        "sit_down_id": {
          "type": "string",
          "description": "Sit-down ID for message insertion and operation tracking"
        },
        "member_id": {
          "type": "string",
          "description": "Caporegime member ID"
        },
        "access_token": {
          "type": "string",
          "description": "Supabase access token"
        },
        "member": {
          "type": "object",
          "description": "Member object with name"
        },
        "context": {
          "type": "object",
          "description": "Additional context including owner_id"
        },
        "reply_to_id": {
          "type": "string",
          "description": "Message ID being replied to"
        },
        "max_turns": {
          "type": "integer",
          "description": "Maximum agentic loop turns (default: 30)"
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "content": {
          "type": "string",
          "description": "Final report text from the caporegime"
        },
        "message_id": {
          "type": "string",
          "description": "Inserted report message ID"
        },
        "operation_id": {
          "type": "string",
          "description": "Operation record ID for tracking"
        },
        "turns": {
          "type": "integer",
          "description": "Number of agentic loop turns used"
        },
        "usage": {
          "type": "object",
          "description": "Aggregate token usage across all turns"
        }
      }
    }
  },
  "dependencies": {
    "static": [
      { "ref": "catalyst:moonmoon69.supabase:0.3.1", "reason": "DB operations" },
      { "ref": "catalyst:moonmoon69.claude:1.0.0", "reason": "Claude provider" },
      { "ref": "catalyst:moonmoon69.openai:1.0.0", "reason": "OpenAI provider" },
      { "ref": "catalyst:moonmoon69.gemini:1.0.0", "reason": "Gemini provider" },
      { "ref": "catalyst:moonmoon69.grok:1.0.0", "reason": "Grok provider" },
      { "ref": "catalyst:moonmoon69.openrouter:1.0.0", "reason": "OpenRouter provider" },
      { "ref": "formula:local.consul:0.1.0", "reason": "Soldier delegation" },
      { "ref": "formula:local.bookkeeper:0.1.0", "optional": true, "reason": "Bookkeeper operations" }
    ]
  },
  "examples": [
    {
      "name": "Run an agentic task",
      "description": "Execute a multi-turn agentic operation with tool use and crew delegation",
      "input": {
        "catalyst_ref": "catalyst:moonmoon69.claude:1.0.0",
        "model": "claude-sonnet-4-6",
        "system": "You handle operations for the Family.",
        "conversation": [{ "role": "user", "content": "Research the latest market trends and compile a report." }],
        "member": { "name": "The Caporegime" },
        "member_id": "mem-capo-1",
        "sit_down_id": "sd-1",
        "access_token": "eyJ...",
        "context": { "owner_id": "user-1" },
        "max_turns": 10
      },
      "output": {
        "content": "Operation complete. Here's the report...",
        "message_id": "msg-1",
        "operation_id": "op-1",
        "turns": 5,
        "usage": { "input_tokens": 5000, "output_tokens": 2000 }
      }
    }
  ]
}
