{$SITE_DOMAIN:localhost} {
	# CYFR Emissary (MCP/API)
	handle /mcp* {
		request_header -Origin
		reverse_proxy cyfr:4000
	}

	# CYFR execution event streaming (SSE) — flush immediately so events aren't buffered
	handle /api/* {
		reverse_proxy cyfr:4000 {
			flush_interval -1
		}
	}

	# Informant REST endpoint — proxied to inform-proxy sidecar
	handle /inform {
		reverse_proxy inform-proxy:4002
	}

	# Frontend SPA (static files with client-side routing fallback)
	handle {
		root * /srv
		try_files {path} {path}.html /index.html
		file_server
	}
}
