{$SITE_DOMAIN:localhost} {
	# CYFR Emissary (MCP/API)
	handle /mcp* {
		request_header -Origin
		reverse_proxy cyfr:4000
	}

	# CYFR execution event streaming (SSE)
	handle /api/* {
		reverse_proxy cyfr:4000
	}

	# Informant REST endpoint — proxied to inform-proxy sidecar
	handle /inform {
		reverse_proxy inform-proxy:4002
	}
	# Proxy Supabase traffic to bypass GFW
	handle /supabase/* {
		uri strip_prefix /supabase
		reverse_proxy {$UPSTREAM_SUPABASE_URL} {
			# Supabase Cloud requires the Host header to match the project ref
			header_up Host aozxiyxossszlfcuwhbm.supabase.co
			header_up X-Real-IP {remote}
			header_up X-Forwarded-For {remote}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Frontend SPA (static files with client-side routing fallback)
	handle {
		root * /srv
		try_files {path} {path}.html /index.html
		file_server
	}
}
